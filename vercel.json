{
    "builds": [
        {
            "src": "crm_project/wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "crm_project/wsgi.py"
        }
    ],
    "env": {
        "DJANGO_SETTINGS_MODULE": "crm_project.settings"
    }
}